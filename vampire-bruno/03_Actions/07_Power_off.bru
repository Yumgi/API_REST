meta {
  name: 07 Power off
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/vms/{{vm_id}}/power_off
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Status stopped", function() {
    expect(res.body.status).to.equal("stopped");
  });
}
